# FinTax Server — Environment Variables Template
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=production

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=FinTax
DB_NAME=fintax_web
CRAWLER_DB_NAME=fintax_crawler

# JWT
JWT_SECRET=<generate-a-strong-random-secret>
JWT_EXPIRES_IN=7d

# Frontend URL (CORS) — your Vercel domain
CLIENT_URL=https://fintax-client.vercel.app

# Public URL of this server — your Render domain
SERVER_PUBLIC_URL=https://fintax-api.onrender.com

# Python (for image gen — disabled on free tier)
PYTHON_COMMAND=python3
AI_IMAGE_AUTOGEN_ENABLED=false

# Groq (RAG / AI Chat)
GROQ_API_KEY=<your-groq-api-key>
GROQ_API_KEY_2=<your-groq-api-key-2>
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_PRIMARY=openai/gpt-oss-120b
GROQ_MODEL_FALLBACK=llama-3.3-70b-versatile
GROQ_ROUTER_MODEL=openai/gpt-oss-20b

# Telegram Bot
TELEGRAM_BOT_TOKEN=<your-bot-token>
